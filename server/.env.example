# Server
PORT=3001
NODE_ENV=production

# Database — use 'mysql' for production, 'sqlite' for local dev
DB_TYPE=mysql
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=animatekids

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Only needed for dev (not used in production since frontend is same-origin)
CORS_ORIGIN=http://localhost:5173
